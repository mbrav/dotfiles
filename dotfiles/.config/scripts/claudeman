#!/usr/bin/env bash
# claudeman — interactive Claude Code session manager.
# Lists sessions in fzf; actions: resume / delete / rename.
set -euo pipefail

script_dir="$(cd "$(dirname "$(realpath "$0")")" && pwd)"
# shellcheck source=_util
source "${script_dir}/_util"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  echo "Usage: claudeman [-a]"
  echo "  Lists Claude Code sessions for the current directory in fzf."
  echo "  -a  show sessions from all projects"
  echo "  -h  show help"
  echo "  Actions: resume | delete | rename"
  exit 0
fi

for dep in fzf jq rg; do
  command -v "$dep" >/dev/null || error_msg "Missing dependency: $dep" 1
done

SHOW_ALL=0
[[ "${1:-}" == "-a" || "${1:-}" == "--all" ]] && SHOW_ALL=1

CLAUDE_DIR="${HOME}/.claude"
SESSIONS_DIR="${CLAUDE_DIR}/sessions"
PROJECTS_DIR="${CLAUDE_DIR}/projects"

# US (0x1f): a non-whitespace field separator. `read`/awk split on it without
# collapsing empties — unlike tab, which `read` treats as whitespace and folds.
US=$'\x1f'

# Claude names a project dir after its cwd with every non-alphanumeric char -> "-".
slugify() { printf '%s' "$1" | sed 's/[^a-zA-Z0-9]/-/g'; }

project_dir="${PROJECTS_DIR}/$(slugify "$PWD")"
if [[ $SHOW_ALL -eq 0 && ! -d "$project_dir" ]]; then
  error_msg "No Claude sessions for: $PWD" 1
fi

# ── Live-session index (live = a running `claude` PID) ────────────────────────
# Populated by index_live_sessions from ~/.claude/sessions/<pid>.json.
declare -A LIVE      # sessionId  -> name US status US session_file US cwd
declare -A LIVE_REC  # cwd-slug   -> sessionId US name US status US session_file US cwd
declare -A LIVE_AT   # cwd-slug   -> startedAt (keeps the newest session per project)

# The slug index is a startup-race fallback: a fresh `claude` has a live PID and a
# cwd before its sessionId is written, so the JSONL can't be matched by id yet.
index_live_sessions() {
  local f pid sid name status cwd started slug
  local -a fields
  LIVE=() LIVE_REC=() LIVE_AT=()

  for f in "${SESSIONS_DIR}"/*.json; do
    [[ -f "$f" ]] || continue
    pid=$(basename "$f" .json)
    kill -0 "$pid" 2>/dev/null || continue

    # One value per line + mapfile keeps empty fields aligned (tab + `read` folds).
    mapfile -t fields < <(jq -r \
      '.sessionId // "", .name // "", .status // "?", .cwd // "", (.startedAt // 0)' \
      "$f" 2>/dev/null)
    [[ ${#fields[@]} -ge 5 ]] || continue
    sid=${fields[0]} name=${fields[1]:-—} status=${fields[2]} cwd=${fields[3]} started=${fields[4]}

    [[ -n $sid ]] && LIVE[$sid]="${name}${US}${status}${US}${f}${US}${cwd}"

    [[ -n $cwd ]] || continue
    slug=$(slugify "$cwd")
    if ((started >= ${LIVE_AT[$slug]:-0})); then
      LIVE_AT[$slug]=$started
      LIVE_REC[$slug]="${sid}${US}${name}${US}${status}${US}${f}${US}${cwd}"
    fi
  done
}

# Read a dead session's name + cwd from its JSONL. Always prints exactly two
# lines (name, then cwd) so callers can mapfile it; either may be empty.
jsonl_meta() {
  local jsonl="$1" name cwd
  name=$(grep -m1 '"type":"custom-title"' "$jsonl" 2>/dev/null |
    jq -r '.customTitle // empty' 2>/dev/null) || true
  cwd=$(grep -m1 '"cwd"' "$jsonl" 2>/dev/null |
    jq -r '.cwd // empty' 2>/dev/null) || true
  printf '%s\n%s\n' "$name" "$cwd"
}

# Print JSONL paths newest-first: all projects (-a) or just the current one.
collect_jsonl_files() {
  if [[ $SHOW_ALL -eq 0 ]]; then
    ls -t "${project_dir}"/*.jsonl 2>/dev/null || true
    return
  fi
  # GNU (Linux) and BSD (macOS) stat take different format flags; the wrong one
  # yields no files and a misleading "No sessions found."
  local -a statcmd=(stat -c '%Y %n')
  [[ "$(uname -s)" == "Linux" ]] || statcmd=(stat -f '%m %N')
  rg --files --null --glob '*.jsonl' --max-depth 2 "$PROJECTS_DIR" 2>/dev/null |
    xargs -0 "${statcmd[@]}" 2>/dev/null |
    sort -rn | awk '{print $2}' || true
}

# Progress bar to stderr (only when stderr is a terminal). Usage: bar pct width
bar() {
  [[ -t 2 ]] || return 0
  local filled=$(($1 * $2 / 100)) prog empty
  printf -v prog "%${filled}s" ""
  printf -v empty "%$(($2 - filled))s" ""
  printf 'Indexing sessions: [%s%s] %3d%%\r' "${prog// /-}" "$empty" "$1" >&2
}

# Emit one US-separated record per session, newest first. Columns:
#   sid US name US status US date US size US alive US session_file US slug US cwd
build_session_list() {
  local -a files
  mapfile -t files < <(collect_jsonl_files)
  local total=${#files[@]} i=0
  local jsonl sid slug name status sf cwd alive luid mtime size
  local -a meta

  for jsonl in "${files[@]}"; do
    [[ -f "$jsonl" ]] || continue
    bar $((++i * 100 / total)) 30

    sid=$(basename "$jsonl" .jsonl)
    slug=$(basename "$(dirname "$jsonl")")
    name="" status="" sf="" cwd="" alive=dead

    if [[ -n ${LIVE[$sid]:-} ]]; then
      IFS="$US" read -r name status sf cwd <<<"${LIVE[$sid]}"
      alive=live
    elif [[ -n ${LIVE_REC[$slug]:-} ]]; then
      IFS="$US" read -r luid name status sf cwd <<<"${LIVE_REC[$slug]}"
      # Live only if this JSONL is that session (or its id isn't written yet).
      [[ -z $luid || $luid == "$sid" ]] && alive=live
    fi

    if [[ $alive == dead ]]; then
      status=dead sf=""
      mapfile -t meta < <(jsonl_meta "$jsonl")
      name=${meta[0]} cwd=${meta[1]}
    fi

    mtime=$(date -r "$jsonl" '+%Y-%m-%d %H:%M')
    size=$(($(wc -c <"$jsonl") / 1024))k
    printf '%s\n' "${sid}${US}${name:-—}${US}${status}${US}${mtime}${US}${size}${US}${alive}${US}${sf}${US}${slug}${US}${cwd}"
  done
  [[ -t 2 ]] && printf '%*s\r' "$(tput cols 2>/dev/null || echo 80)" "" >&2
}

# fzf session picker over the US-separated list; prints the chosen sid, or
# returns non-zero on cancel. Returning (not exiting) matters: this runs in a
# command-substitution subshell, so an `exit` here would only kill the subshell
# and let the main loop redraw fzf — making it impossible to escape.
pick_session() {
  local list="$1" fmt header sel
  if [[ $SHOW_ALL -eq 1 ]]; then
    fmt='{ printf "%s  %-36s  %-10s  %-16s  %-6s  %-32s  %s\n", ($6=="live"?"●":"○"), $1, $3, $4, $5, $2, $8 }'
    header=$(printf '     %-36s  %-10s  %-16s  %-6s  %-32s  %s' UUID STATUS DATE SIZE NAME PROJECT)
  else
    fmt='{ printf "%s  %-36s  %-10s  %-16s  %-6s  %s\n", ($6=="live"?"●":"○"), $1, $3, $4, $5, $2 }'
    header=$(printf '     %-36s  %-10s  %-16s  %-6s  %s' UUID STATUS DATE SIZE NAME)
  fi

  sel=$(awk -F"$US" "$fmt" <<<"$list" | fzf \
    --ansi \
    --header="$header" \
    --prompt="Session › " \
    --layout=reverse \
    --border \
    --height=50%) || return 1
  awk '{print $2}' <<<"$sel"
}

# fzf action picker; prints the chosen action or returns non-zero on cancel.
pick_action() {
  printf 'resume\ndelete\nrename\n' | fzf \
    --prompt="Action [$1] › " \
    --layout=reverse \
    --border \
    --height=20%
}

cancel() {
  info_msg "Cancelled."
  exit 0
}

# ── Main ──────────────────────────────────────────────────────────────────────

while true; do
  index_live_sessions

  list=$(build_session_list)
  [[ -n "$list" ]] || error_msg "No sessions found." 1

  # Esc at the session picker quits; Esc at the action picker steps back here.
  sid=$(pick_session "$list") || cancel
  [[ -n "$sid" ]] || cancel

  # Pull the chosen row's fields in one pass (US-split preserves empties).
  IFS="$US" read -r _ name _ _ _ alive sf slug real_cwd \
    < <(awk -F"$US" -v s="$sid" '$1==s{print; exit}' <<<"$list")
  jsonl="${PROJECTS_DIR}/${slug}/${sid}.jsonl"

  action=$(pick_action "$name") || continue
  [[ -n "$action" ]] || continue

  case "$action" in

  resume)
    if [[ -n "$real_cwd" && -d "$real_cwd" ]]; then
      info_msg "Resuming: ${name} (${sid}) in ${real_cwd}"
      cd "$real_cwd"
    else
      info_msg "Resuming: ${name} (${sid})"
    fi
    exec claude --resume "$sid"
    ;;

  delete)
    warning_msg "About to permanently delete:"
    echo "  ${BOLD}JSONL   :${CLEAR} ${jsonl}"
    [[ -n "$sf" ]] && echo "  ${BOLD}Session :${CLEAR} ${sf}"
    yes_no_prompt "Delete session '${name}'?" || {
      info_msg "Aborted."
      continue
    }
    rm -f "$jsonl"
    [[ -n "$sf" ]] && rm -f "$sf"
    success_msg "Deleted ${sid}"
    ;;

  rename)
    if [[ "$alive" != "live" ]]; then
      warning_msg "Session is not live — cannot rename."
      info_msg "To set name on resume: claude --resume ${sid} --name <new-name>"
      continue
    fi
    read -r -p "${CYAN}New name for '${name}': ${CLEAR}" new_name
    [[ -z "$new_name" ]] && error_msg "Name cannot be empty." 1
    tmp=$(mktemp)
    jq --arg n "$new_name" '.name = $n' "$sf" >"$tmp" && mv "$tmp" "$sf"
    success_msg "Renamed to '${new_name}'"
    ;;

  esac
done
