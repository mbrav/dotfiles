# Create a new tmux window with an optional custom name.
# If the name is left empty, the current directory basename is used.
# Intended to be launched via a tmux display-popup binding.

script_dir="$(dirname "$(realpath "$0")")"
source "${script_dir}/_util"

read -rp "${CYAN}Window name ${YELLOW}(empty = dir name)${CLEAR}: " win_name

if [[ -z "$win_name" ]]; then
  win_name="$(basename "$PWD")"
  info_msg "Using directory name: ${BOLD}${win_name}${CLEAR}" ""
fi

tmux new-window -n "$win_name" -c "$PWD"
success_msg "Opened: ${win_name}"
