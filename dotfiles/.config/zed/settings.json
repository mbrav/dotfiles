// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "terminal": {
    "font_family": "Iosevka Nerd Font",
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "agent": {
    "default_model": {
      "provider": "openai",
      "model": "gpt-5.3-codex",
    },
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "right",
  },
  "assistant": {
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-3-7-sonnet-latest",
    },
  },
  "project_panel": {
    "dock": "right",
  },
  // Disabling linked edits because of: https://github.com/zed-industries/zed/issues/25586
  // "linked_edits": false,
  "hide_mouse": "on_typing_and_movement",
  // Will be triggered manually with `ctrl-x ctrl-c`.
  // "show_edit_predictions": true,
  "inlay_hints": {
    "enabled": false,
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Ayu Dark",
  },
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 18,
  "cursor_blink": true,
  "tab_bar": {
    "show": true,
  },
  "scrollbar": {
    "show": "never",
  },
  // Rainbow indentation
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  "preview_tabs": {
    "enabled": false,
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
    },
  },
  "vim": {
    "use_system_clipboard": "always",
  },
  "languages": {
    "LaTeX": {
      "soft_wrap": "preferred_line_length",
    },
  },
  "wrap_guides": [90],
}
